{
  "expo": {
    "name": "GrocerEase Rider",
    "slug": "grocerease-rider",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "UIBackgroundModes": [
          "location"
        ]
      },
      "bundleIdentifier": "com.grocereasetv.rider"
    },
    "android": {
      "package": "com.grocereasetv.rider",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow GrocerEase Rider to use your location for delivery tracking.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "description": "GrocerEase delivery partner app",
    "scheme": "grocerease-rider"
  }
}
